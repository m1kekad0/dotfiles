# グローバル gitignore
# すべてのリポジトリで除外するファイル・ディレクトリを定義する

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── エディタ・IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.netrwhist

# ─── 環境変数・機密情報 ────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─── Claude Code ──────────────────────────────────────────────────────────────
settings.local.json

# ─── ログ・一時ファイル ────────────────────────────────────────────────────────
*.log
*.tmp
*.bak

# ─── Node.js ──────────────────────────────────────────────────────────────────
node_modules/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/

# ─── Go ───────────────────────────────────────────────────────────────────────
/vendor/
